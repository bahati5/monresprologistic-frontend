# Production / build : URL absolue de l’API Laravel.
# En `npm run dev`, le client utilise une baseURL vide et Vite proxy vers l’API (voir vite.config.ts) ;
# VITE_API_URL n’est alors pas utilisée pour les requêtes axios.
VITE_API_URL=http://localhost:8000

# Optionnel : cible du proxy si le backend n’est pas sur localhost:8000
# VITE_PROXY_TARGET=http://127.0.0.1:8000
